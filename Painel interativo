import { useState, useEffect } from "react";
import { RadarChart, Radar, PolarGrid, PolarAngleAxis, ResponsiveContainer, BarChart, Bar, XAxis, YAxis, Tooltip, Cell } from "recharts";

const SCENARIOS = [
  { id: 1, key: "colapso", label: "Colapso Rápido", emoji: "🟢", color: "#22c55e", desc: "Regime iraniano cai em 2–4 semanas" },
  { id: 2, key: "prolongada", label: "Guerra Prolongada", emoji: "🔥", color: "#f97316", desc: "Conflito dura 3–12 meses" },
  { id: 3, key: "escalada", label: "Escalada Global", emoji: "💥", color: "#ef4444", desc: "Grandes potências envolvidas" },
  { id: 4, key: "ceasar", label: "Cessar-Fogo", emoji: "🕊️", color: "#3b82f6", desc: "Negociação mediada" },
];

const THEORIES = ["Jogos", "Bayesiana", "Markov", "Utilidade", "Caos+EVT"];

const DEFAULT_DATA = {
  colapso:    [15, 12, 8,  10, 5],
  prolongada: [50, 55, 45, 60, 45],
  escalada:   [15, 15, 25, 12, 25],
  ceasar:     [20, 18, 22, 18, 25],
};

const SYSTEM_PROMPT = `Você é um analista geopolítico e matemático especializado em teoria dos jogos, probabilidade bayesiana, cadeias de Markov, teoria da utilidade esperada e teoria do caos.

Sua tarefa é analisar as últimas notícias sobre o conflito Israel-Irã-EUA e ATUALIZAR as probabilidades dos 4 cenários usando 5 frameworks matemáticos.

Os 4 cenários são:
1. colapso: Colapso rápido do regime iraniano (2-4 semanas)
2. prolongada: Guerra prolongada (3-12 meses)
3. escalada: Escalada regional com grandes potências (Rússia/China envolvidas)
4. ceasar: Cessar-fogo negociado por mediação

Os 5 frameworks são (em ordem): Jogos, Bayesiana, Markov, Utilidade, Caos+EVT

REGRAS:
- Cada coluna (framework) deve somar exatamente 100
- Valores inteiros entre 0 e 100
- Baseie-se nas notícias recentes para calibrar os valores
- Seja preciso e analítico

Responda APENAS com JSON válido neste formato exato, sem markdown, sem texto extra:
{
  "data": {
    "colapso":    [v1, v2, v3, v4, v5],
    "prolongada": [v1, v2, v3, v4, v5],
    "escalada":   [v1, v2, v3, v4, v5],
    "ceasar":     [v1, v2, v3, v4, v5]
  },
  "summary": "Resumo em 2-3 frases dos principais eventos que motivaram as mudanças nas probabilidades.",
  "highlights": ["Evento chave 1", "Evento chave 2", "Evento chave 3"]
}`;

export default function WarTracker() {
  const [data, setData] = useState(DEFAULT_DATA);
  const [loading, setLoading] = useState(false);
  const [lastUpdate, setLastUpdate] = useState(null);
  const [summary, setSummary] = useState("");
  const [highlights, setHighlights] = useState([]);
  const [error, setError] = useState("");
  const [activeTab, setActiveTab] = useState("bar");
  const [pulseKey, setPulseKey] = useState(0);

  const avg = (arr) => Math.round(arr.reduce((a, b) => a + b, 0) / arr.length);

  const fetchUpdate = async () => {
    setLoading(true);
    setError("");
    try {
      const response = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "claude-sonnet-4-20250514",
          max_tokens: 1000,
          tools: [{ type: "web_search_20250305", name: "web_search" }],
          system: SYSTEM_PROMPT,
          messages: [{
            role: "user",
            content: `Busque as últimas notícias de hoje sobre o conflito Israel Irã EUA guerra 2026 e atualize as probabilidades dos cenários. Data atual: ${new Date().toLocaleDateString("pt-BR")}.`
          }]
        })
      });

      const result = await response.json();
      const text = result.content
        .filter(b => b.type === "text")
        .map(b => b.text)
        .join("");

      const clean = text.replace(/```json|```/g, "").trim();
      const parsed = JSON.parse(clean);

      setData(parsed.data);
      setSummary(parsed.summary);
      setHighlights(parsed.highlights || []);
      setLastUpdate(new Date());
      setPulseKey(k => k + 1);
    } catch (e) {
      setError("Erro ao buscar atualização. Tente novamente.");
    }
    setLoading(false);
  };

  const barData = SCENARIOS.map(s => ({
    name: s.label,
    value: avg(data[s.key]),
    color: s.color,
    emoji: s.emoji,
  }));

  const radarData = THEORIES.map((t, i) => {
    const obj = { theory: t };
    SCENARIOS.forEach(s => { obj[s.label] = data[s.key][i]; });
    return obj;
  });

  return (
    <div style={{
      minHeight: "100vh",
      background: "linear-gradient(135deg, #0a0e1a 0%, #0f1629 50%, #0a0e1a 100%)",
      fontFamily: "'Georgia', 'Times New Roman', serif",
      color: "#e2e8f0",
      padding: "24px",
    }}>
      {/* Header */}
      <div style={{ textAlign: "center", marginBottom: "32px", position: "relative" }}>
        <div style={{
          fontSize: "11px", letterSpacing: "4px", color: "#f97316",
          textTransform: "uppercase", marginBottom: "8px", fontFamily: "monospace"
        }}>
          ANÁLISE ESTRATÉGICA • AO VIVO
        </div>
        <h1 style={{
          fontSize: "clamp(22px, 4vw, 36px)", fontWeight: "bold",
          background: "linear-gradient(90deg, #f97316, #fbbf24, #f97316)",
          WebkitBackgroundClip: "text", WebkitTextFillColor: "transparent",
          margin: "0 0 8px",
          letterSpacing: "-0.5px"
        }}>
          Israel · Irã · EUA
        </h1>
        <p style={{ color: "#94a3b8", fontSize: "14px", margin: 0 }}>
          Monitor de Probabilidades por Teoria Matemática
        </p>

        {lastUpdate && (
          <div style={{
            display: "inline-flex", alignItems: "center", gap: "6px",
            marginTop: "12px", background: "rgba(34,197,94,0.1)",
            border: "1px solid rgba(34,197,94,0.3)", borderRadius: "20px",
            padding: "4px 12px", fontSize: "12px", color: "#22c55e"
          }}>
            <span style={{ width: 6, height: 6, borderRadius: "50%", background: "#22c55e", display: "inline-block" }} />
            Atualizado: {lastUpdate.toLocaleString("pt-BR")}
          </div>
        )}
      </div>

      {/* Update Button */}
      <div style={{ textAlign: "center", marginBottom: "28px" }}>
        <button
          onClick={fetchUpdate}
          disabled={loading}
          style={{
            background: loading ? "rgba(249,115,22,0.3)" : "linear-gradient(135deg, #f97316, #dc2626)",
            border: "none", borderRadius: "8px", color: "white",
            padding: "12px 32px", fontSize: "15px", fontWeight: "bold",
            cursor: loading ? "not-allowed" : "pointer",
            boxShadow: loading ? "none" : "0 4px 20px rgba(249,115,22,0.4)",
            transition: "all 0.3s", letterSpacing: "0.5px",
            fontFamily: "monospace"
          }}
        >
          {loading ? "⟳  Buscando notícias e calculando..." : "⟳  Atualizar com Notícias de Hoje"}
        </button>
        {error && <p style={{ color: "#ef4444", marginTop: "8px", fontSize: "13px" }}>{error}</p>}
      </div>

      {/* Summary */}
      {summary && (
        <div style={{
          background: "rgba(255,255,255,0.04)", border: "1px solid rgba(249,115,22,0.2)",
          borderRadius: "12px", padding: "16px 20px", marginBottom: "24px",
          borderLeft: "3px solid #f97316"
        }}>
          <div style={{ fontSize: "11px", color: "#f97316", letterSpacing: "2px", marginBottom: "8px", fontFamily: "monospace" }}>
            ANÁLISE DO DIA
          </div>
          <p style={{ margin: 0, lineHeight: 1.7, color: "#cbd5e1", fontSize: "14px" }}>{summary}</p>
          {highlights.length > 0 && (
            <div style={{ marginTop: "12px", display: "flex", flexWrap: "wrap", gap: "8px" }}>
              {highlights.map((h, i) => (
                <span key={i} style={{
                  background: "rgba(249,115,22,0.1)", border: "1px solid rgba(249,115,22,0.2)",
                  borderRadius: "4px", padding: "3px 10px", fontSize: "12px", color: "#fbbf24"
                }}>
                  {h}
                </span>
              ))}
            </div>
          )}
        </div>
      )}

      {/* Scenario Cards */}
      <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fit, minmax(200px, 1fr))", gap: "16px", marginBottom: "28px" }}>
        {SCENARIOS.map(s => {
          const mean = avg(data[s.key]);
          return (
            <div key={s.id} style={{
              background: "rgba(255,255,255,0.04)",
              border: `1px solid ${s.color}40`,
              borderTop: `3px solid ${s.color}`,
              borderRadius: "12px", padding: "18px",
              transition: "transform 0.2s",
            }}>
              <div style={{ fontSize: "22px", marginBottom: "6px" }}>{s.emoji}</div>
              <div style={{ fontWeight: "bold", fontSize: "14px", color: "#f1f5f9", marginBottom: "4px" }}>{s.label}</div>
              <div style={{ color: "#94a3b8", fontSize: "12px", marginBottom: "14px" }}>{s.desc}</div>
              <div style={{ fontSize: "38px", fontWeight: "bold", color: s.color, fontFamily: "monospace", lineHeight: 1 }}>
                {mean}%
              </div>
              <div style={{ fontSize: "11px", color: "#64748b", marginTop: "4px" }}>média das 5 teorias</div>
              <div style={{ marginTop: "12px", display: "flex", gap: "4px", flexWrap: "wrap" }}>
                {data[s.key].map((v, i) => (
                  <div key={i} title={THEORIES[i]} style={{
                    height: "4px", flex: 1, borderRadius: "2px",
                    background: s.color, opacity: 0.3 + (v / 100) * 0.7
                  }} />
                ))}
              </div>
            </div>
          );
        })}
      </div>

      {/* Chart Tabs */}
      <div style={{
        background: "rgba(255,255,255,0.04)", border: "1px solid rgba(255,255,255,0.08)",
        borderRadius: "12px", padding: "20px", marginBottom: "24px"
      }}>
        <div style={{ display: "flex", gap: "12px", marginBottom: "20px" }}>
          {["bar", "radar"].map(tab => (
            <button key={tab} onClick={() => setActiveTab(tab)} style={{
              background: activeTab === tab ? "rgba(249,115,22,0.2)" : "transparent",
              border: `1px solid ${activeTab === tab ? "#f97316" : "rgba(255,255,255,0.1)"}`,
              color: activeTab === tab ? "#f97316" : "#94a3b8",
              borderRadius: "6px", padding: "6px 16px", cursor: "pointer",
              fontSize: "12px", fontFamily: "monospace", letterSpacing: "1px", textTransform: "uppercase"
            }}>
              {tab === "bar" ? "Barras" : "Radar"}
            </button>
          ))}
        </div>

        {activeTab === "bar" && (
          <ResponsiveContainer width="100%" height={220}>
            <BarChart data={barData} barSize={40}>
              <XAxis dataKey="name" tick={{ fill: "#94a3b8", fontSize: 12 }} axisLine={false} tickLine={false} />
              <YAxis tick={{ fill: "#64748b", fontSize: 11 }} domain={[0, 100]} axisLine={false} tickLine={false} tickFormatter={v => `${v}%`} />
              <Tooltip
                contentStyle={{ background: "#0f1629", border: "1px solid #f97316", borderRadius: "8px", color: "#e2e8f0" }}
                formatter={(v) => [`${v}%`, "Probabilidade Média"]}
              />
              <Bar dataKey="value" radius={[6, 6, 0, 0]}>
                {barData.map((entry, i) => <Cell key={i} fill={entry.color} />)}
              </Bar>
            </BarChart>
          </ResponsiveContainer>
        )}

        {activeTab === "radar" && (
          <ResponsiveContainer width="100%" height={260}>
            <RadarChart data={radarData}>
              <PolarGrid stroke="rgba(255,255,255,0.1)" />
              <PolarAngleAxis dataKey="theory" tick={{ fill: "#94a3b8", fontSize: 11 }} />
              {SCENARIOS.map(s => (
                <Radar key={s.key} name={s.label} dataKey={s.label}
                  stroke={s.color} fill={s.color} fillOpacity={0.15} strokeWidth={2} />
              ))}
              <Tooltip contentStyle={{ background: "#0f1629", border: "1px solid #334155", borderRadius: "8px", fontSize: 12 }}
                formatter={(v) => [`${v}%`]} />
            </RadarChart>
          </ResponsiveContainer>
        )}
      </div>

      {/* Full Table */}
      <div style={{
        background: "rgba(255,255,255,0.04)", border: "1px solid rgba(255,255,255,0.08)",
        borderRadius: "12px", padding: "20px", overflowX: "auto"
      }}>
        <div style={{ fontSize: "11px", color: "#f97316", letterSpacing: "2px", marginBottom: "14px", fontFamily: "monospace" }}>
          TABELA COMPLETA
        </div>
        <table style={{ width: "100%", borderCollapse: "collapse", fontSize: "13px" }}>
          <thead>
            <tr>
              <th style={{ textAlign: "left", padding: "8px 12px", color: "#64748b", fontWeight: "normal", fontSize: "11px", borderBottom: "1px solid rgba(255,255,255,0.08)" }}>CENÁRIO</th>
              {THEORIES.map(t => (
                <th key={t} style={{ textAlign: "center", padding: "8px 12px", color: "#64748b", fontWeight: "normal", fontSize: "11px", borderBottom: "1px solid rgba(255,255,255,0.08)", whiteSpace: "nowrap" }}>{t}</th>
              ))}
              <th style={{ textAlign: "center", padding: "8px 12px", color: "#f97316", fontWeight: "bold", fontSize: "11px", borderBottom: "1px solid rgba(255,255,255,0.08)" }}>MÉDIA</th>
            </tr>
          </thead>
          <tbody>
            {SCENARIOS.map((s, si) => (
              <tr key={s.key} style={{ borderBottom: "1px solid rgba(255,255,255,0.04)" }}>
                <td style={{ padding: "10px 12px", color: "#e2e8f0" }}>
                  <span style={{ marginRight: "8px" }}>{s.emoji}</span>
                  <span style={{ color: s.color, fontWeight: "bold" }}>{s.label}</span>
                </td>
                {data[s.key].map((v, i) => (
                  <td key={i} style={{
                    textAlign: "center", padding: "10px 12px",
                    fontFamily: "monospace", fontWeight: "bold",
                    color: v === Math.max(...data[s.key]) ? s.color : "#94a3b8",
                    fontSize: v === Math.max(...data[s.key]) ? "15px" : "13px"
                  }}>
                    {v}%
                  </td>
                ))}
                <td style={{
                  textAlign: "center", padding: "10px 12px",
                  fontFamily: "monospace", fontWeight: "bold", color: s.color, fontSize: "15px"
                }}>
                  {avg(data[s.key])}%
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div style={{ textAlign: "center", marginTop: "24px", color: "#334155", fontSize: "11px", fontFamily: "monospace" }}>
        Powered by Claude + Web Search • Atualização manual diária recomendada
      </div>
    </div>
  );
}
